# Copy to .env.local and fill in real values. Never commit .env.local.

# OIDC / Auth
NEXT_PUBLIC_STS_AUTHORITY=https://dev.id.eris.efda.gov.et
NEXT_PUBLIC_CLIENT_ID=eris-portal-spa
NEXT_PUBLIC_CLIENT_ROOT=http://localhost:4200
NEXT_PUBLIC_REDIRECT_URI=http://localhost:4200/auth-callback?to=signin
NEXT_PUBLIC_SILENT_REDIRECT_URI=http://localhost:4200/assets/silent-callback.html
NEXT_PUBLIC_POST_LOGOUT_REDIRECT_URI=http://localhost:4200
NEXT_PUBLIC_CLIENT_SCOPE=openid profile
NEXT_PUBLIC_RESPONSE_TYPE=code

# API
NEXT_PUBLIC_API_ROOT=https://api.feature.eris.efda.gov.et/api
NEXT_PUBLIC_API_KPI=https://api.feature.eris.efda.gov.et/api/kpi

# Read-only ERIS dev database (scripts/db-query.js + MCP postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
